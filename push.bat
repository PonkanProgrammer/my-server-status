@echo off
echo ==========================================
echo GitHubへアップロードを開始します...
echo ==========================================

:: 変更をすべて登録
git add .

:: コミット（今日の日付をメッセージにする）
git commit -m "Auto-update: %date% %time%"

:: GitHubへ送信
git push -u origin main --force

echo ==========================================
echo アップロード完了しました！
echo ==========================================
pause